$(document).ready(function(){
$("#contactForm").validator().on("submit", function (event) {
    if (event.isDefaultPrevented()) {
        // обработка ошибки формы...
    } else {
        // все в порядке!
        event.preventDefault();
        submitForm();
    }
});
function submitForm(){
    // Инициируем переменную с содержимым формы
    var name = $("#name").val();
    var email = $("#email").val();
    var message = $("#message").val();
    var order = $("#order").val();
    var price = $("#price").val();
    var format = $("#format").val();
    var price2 = $("#price2").val();
    var cur = $("#cur").val();

    $.ajax({
        type: "POST",
        url: "/mail.php",
        data: "name=" + name + "&email=" + email + "&message=" + message + "&order=" + order + "&price=" + price + "&cur=" + cur  + "&price2=" + price2  + "&format=" + format  + "&url="+window.location.href,
        success : function(text){
            if (text != "fail"){
                formSuccess(text);
            }
        }
    });
}
function formSuccess(text){
    $( "#msgSubmit" ).removeClass( "d-none" );
    $( "#contactForm" ).append( text );
}

});  